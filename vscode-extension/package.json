{
  "name": "aeonforge-code",
  "displayName": "Aeonforge Code",
  "description": "Multi-Agent AI Development System with Claude Code-like capabilities",
  "version": "1.0.0",
  "publisher": "aeonforge",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Other",
    "Productivity"
  ],
  "keywords": [
    "ai",
    "coding",
    "assistant",
    "multi-agent",
    "development"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aeonforge.openChat",
        "title": "Open Aeonforge Chat",
        "category": "Aeonforge"
      },
      {
        "command": "aeonforge.analyzeCodebase", 
        "title": "Analyze Codebase",
        "category": "Aeonforge"
      },
      {
        "command": "aeonforge.generateCode",
        "title": "Generate Code",
        "category": "Aeonforge"
      },
      {
        "command": "aeonforge.refactorCode",
        "title": "Refactor Code",
        "category": "Aeonforge"
      },
      {
        "command": "aeonforge.explainCode",
        "title": "Explain Code",
        "category": "Aeonforge"
      },
      {
        "command": "aeonforge.createProject",
        "title": "Create New Project",
        "category": "Aeonforge"
      },
      {
        "command": "aeonforge.analyzeCurrentFile",
        "title": "Analyze Current File",
        "category": "Aeonforge"
      },
      {
        "command": "aeonforge.convertCode",
        "title": "Convert Code to Another Language",
        "category": "Aeonforge"
      },
      {
        "command": "aeonforge.executeCode",
        "title": "Execute Code",
        "category": "Aeonforge"
      },
      {
        "command": "aeonforge.showQualityReport",
        "title": "Show Code Quality Report",
        "category": "Aeonforge"
      },
      {
        "command": "aeonforge.explainHover",
        "title": "Explain Hover Element",
        "category": "Aeonforge"
      }
    ],
    "keybindings": [
      {
        "command": "aeonforge.openChat",
        "key": "cmd+escape",
        "mac": "cmd+escape",
        "win": "ctrl+escape",
        "linux": "ctrl+escape"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorHasSelection",
          "command": "aeonforge.explainCode",
          "group": "aeonforge@1"
        },
        {
          "when": "editorHasSelection", 
          "command": "aeonforge.refactorCode",
          "group": "aeonforge@2"
        },
        {
          "when": "editorHasSelection",
          "command": "aeonforge.convertCode",
          "group": "aeonforge@3"
        },
        {
          "when": "editorHasSelection",
          "command": "aeonforge.executeCode",
          "group": "aeonforge@4"
        },
        {
          "command": "aeonforge.analyzeCurrentFile",
          "group": "aeonforge@5"
        }
      ],
      "explorer/context": [
        {
          "command": "aeonforge.analyzeCodebase",
          "group": "aeonforge@1"
        }
      ],
      "commandPalette": [
        {
          "command": "aeonforge.explainHover",
          "when": "false"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "aeonforgeChat",
          "name": "Aeonforge Assistant",
          "when": "aeonforge:enabled"
        }
      ]
    },
    "configuration": {
      "title": "Aeonforge Code",
      "properties": {
        "aeonforge.backendUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "URL of the Aeonforge backend server"
        },
        "aeonforge.apiKeys": {
          "type": "object",
          "description": "API keys for external services",
          "properties": {
            "serpapi": {
              "type": "string",
              "description": "SerpAPI key for web search"
            }
          }
        },
        "aeonforge.enableInlineEdits": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline code editing with diff preview"
        },
        "aeonforge.autoSave": {
          "type": "boolean", 
          "default": false,
          "description": "Automatically save files after AI edits"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.x",
    "@typescript-eslint/eslint-plugin": "^6.x",
    "@typescript-eslint/parser": "^6.x",
    "eslint": "^8.x",
    "typescript": "^5.3.x",
    "@vscode/test-cli": "^0.0.x",
    "@vscode/test-electron": "^2.3.x"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "ws": "^8.15.0"
  }
}