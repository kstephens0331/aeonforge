# ========================================
# Aeonforge Environment Configuration
# Copy this file to .env and update values
# ========================================

# ========================================
# ENVIRONMENT SETTINGS
# ========================================
ENVIRONMENT=development
DEBUG=true
API_VERSION=1.0.0
LOG_LEVEL=INFO

# ========================================
# AI PROVIDERS (REQUIRED)
# ========================================

# OpenAI Configuration
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_ORG_ID=your_organization_id_here

# Google Gemini Configuration  
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here

# SerpAPI for Web Search
SERPAPI_KEY=your_serpapi_key_here

# NIH/PubMed API Key
NIH_PUBMED_KEY=your_nih_pubmed_api_key_here

# ========================================
# DATABASE CONFIGURATION
# ========================================

# Primary Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/aeonforge

# Redis Cache
REDIS_URL=redis://localhost:6379/0

# SQLite (for local development)
SQLITE_DATABASE_PATH=./aeonforge.db

# ========================================
# SUPABASE CONFIGURATION
# ========================================

# Supabase Project Settings
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ========================================
# APPLICATION URLS
# ========================================

# Frontend URL (React app)
FRONTEND_URL=http://localhost:3000

# Backend URL (FastAPI)
BACKEND_URL=http://localhost:8000

# API Base URL
API_BASE_URL=http://localhost:8000/api/v1

# ========================================
# SECURITY CONFIGURATION
# ========================================

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your_jwt_secret_key_here_minimum_32_characters

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# API Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# ========================================
# PAYMENT PROCESSING (STRIPE)
# ========================================

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ========================================
# MONITORING & LOGGING
# ========================================

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=300

# Structured Logging
STRUCTURED_LOGGING=true
LOG_FORMAT=json

# Performance Monitoring
PERFORMANCE_MONITORING=true
METRICS_ENABLED=true

# ========================================
# TOOL SYSTEM CONFIGURATION
# ========================================

# Tool Execution Settings
MAX_CONCURRENT_TOOLS=10
TOOL_TIMEOUT_SECONDS=300
TOOL_RETRY_COUNT=3

# Multi-Model AI Routing
MULTI_MODEL_ROUTING=true
DEFAULT_AI_MODEL=chatgpt
FALLBACK_AI_MODELS=gemini,ollama

# Tool Caching
TOOL_CACHE_ENABLED=true
TOOL_CACHE_TTL_SECONDS=3600

# ========================================
# FEATURE FLAGS
# ========================================

# System Features
SELF_HEALING_ENABLED=true
REAL_TIME_UPDATES=true
USAGE_ANALYTICS=true
AUTO_SCALING=false

# Tool Features
BATCH_TOOL_EXECUTION=true
TOOL_CHAINING=true
CUSTOM_TOOLS=false

# ========================================
# DEVELOPMENT SETTINGS
# ========================================

# Development Mode
DEV_MODE=true
HOT_RELOAD=true
DEBUG_TOOLBAR=true

# Testing
TEST_DATABASE_URL=postgresql://username:password@localhost:5432/aeonforge_test
RUN_INTEGRATION_TESTS=false

# ========================================
# PRODUCTION SETTINGS
# (Override in production)
# ========================================

# Production overrides (uncomment for production)
# ENVIRONMENT=production
# DEBUG=false
# LOG_LEVEL=WARNING
# DEV_MODE=false
# HOT_RELOAD=false
# DEBUG_TOOLBAR=false

# Production Security
# SECURE_SSL_REDIRECT=true
# SESSION_COOKIE_SECURE=true
# CSRF_COOKIE_SECURE=true

# Production Performance
# MAX_CONCURRENT_TOOLS=50
# TOOL_CACHE_TTL_SECONDS=7200
# AUTO_SCALING=true

# ========================================
# RAILWAY DEPLOYMENT
# ========================================

# Railway will automatically set these:
# PORT=8000
# RAILWAY_ENVIRONMENT=production
# DATABASE_URL=(automatically set by Railway PostgreSQL)
# REDIS_URL=(automatically set by Railway Redis)

# ========================================
# OPTIONAL INTEGRATIONS
# ========================================

# Slack Integration (for notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Discord Integration (for notifications) 
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/DISCORD/WEBHOOK

# Email Service (for notifications)
EMAIL_SERVICE_API_KEY=your_email_service_api_key_here
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# Sentry (for error tracking)
SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/project_id

# ========================================
# CUSTOM CONFIGURATION
# ========================================

# Add your custom environment variables below
# CUSTOM_FEATURE_FLAG=true
# CUSTOM_API_ENDPOINT=https://api.example.com
# CUSTOM_API_KEY=your_custom_api_key_here

# ========================================
# NOTES
# ========================================

# 1. Never commit the actual .env file to version control
# 2. Generate strong secrets for JWT_SECRET_KEY and other sensitive values
# 3. Use different values for development, staging, and production
# 4. Regularly rotate API keys and secrets
# 5. Ensure proper permissions on .env file (600 recommended)
# 6. Use environment-specific .env files (.env.production, .env.staging)
# 7. Validate all required variables are set before starting the application