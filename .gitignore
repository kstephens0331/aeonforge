# Environment files
.env
.env.*
!.env.example
.envrc

# API Keys and secrets
*.key
*.pem
*.p12
*.pfx
secrets/
api_keys/
credentials/

# Configuration files with potential secrets
config.json
config.yaml
config.yml
settings.json
local_settings.py

# Database credentials
database.url
db_config.json

# Cloud provider configs
.aws/
.gcp/
.azure/

